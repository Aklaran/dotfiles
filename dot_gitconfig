# Shared Git defaults for all machines.
# Per-machine identity lives in ~/.gitconfig.local, which setup bootstraps.

[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[branch]
	autoSetupMerge = true

[rebase]
	updateRefs = true

[diff]
  external = difft

[url "git@github.com:"]
	insteadOf = https://github.com/

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
